{
    "name": "ophiocus/drupal-three-js-theme",
    "description": "Drupal 11 theme rendering the site as a persistent three.js world. See THESIS.md for the philosophical thesis.",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "homepage": "https://github.com/ophiocus/drupal-three-js-theme",
    "repositories": [
        {
            "name": "threed_assets",
            "type": "vcs",
            "url": "https://github.com/ophiocus/threed_assets"
        },
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    ],
    "require": {
        "composer/installers": "^2.3",
        "drupal/admin_toolbar": "^3.6",
        "drupal/advancedqueue": "^1.1",
        "drupal/ai": "^1.1",
        "drupal/ai_provider_anthropic": "^1.1",
        "drupal/core-composer-scaffold": "^11.3",
        "drupal/core-project-message": "^11.3",
        "drupal/core-recipe-unpack": "^11.3",
        "drupal/core-recommended": "^11.3",
        "drupal/migrate_plus": "^6.0",
        "drupal/migrate_tools": "^6.0",
        "drupal/paragraphs": "^1.20",
        "drush/drush": "^13.7",
        "ophiocus/threed_assets": "dev-master"
    },
    "require-dev": {
        "drupal/core-dev": "^11.3",
        "drupal/devel": "^5.3"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-recipe-unpack": true,
            "drupal/core-project-message": true,
            "phpstan/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true,
            "php-tuf/composer-integration": true
        },
        "sort-packages": true
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            }
        },
        "installer-paths": {
            "web/core": [
                "type:drupal-core"
            ],
            "web/libraries/{$name}": [
                "type:drupal-library"
            ],
            "web/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "web/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "web/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "drush/Commands/contrib/{$name}": [
                "type:drupal-drush"
            ],
            "web/modules/custom/{$name}": [
                "type:drupal-custom-module",
                "type:drupal-module-custom"
            ],
            "web/themes/custom/{$name}": [
                "type:drupal-custom-theme",
                "type:drupal-theme-custom"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "Drupal\\world_signature\\": "web/modules/custom/world_signature/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Drupal\\Tests\\world_signature\\": "web/modules/custom/world_signature/tests/src/"
        }
    },
    "scripts": {
        "test:unit": "phpunit --testsuite=unit"
    }
}
